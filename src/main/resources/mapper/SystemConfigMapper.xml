<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.mapper.SystemConfigMapper">

    <resultMap id="BaseResultMap" type="com.fitness.entity.SystemConfig">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="config_desc" property="configDesc"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByKey" resultMap="BaseResultMap">
        SELECT * FROM system_config WHERE config_key = #{configKey}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM system_config ORDER BY id ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO system_config (config_key, config_value, config_desc)
        VALUES (#{configKey}, #{configValue}, #{configDesc})
    </insert>

    <update id="update">
        UPDATE system_config SET config_value = #{configValue}, config_desc = #{configDesc}
        WHERE config_key = #{configKey}
    </update>
</mapper>
